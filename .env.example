# ─── Gemini API key (via Google AI Studio, your AI Pro subscription) ───
# https://aistudio.google.com/app/apikey while signed in to your AI Pro account.
GEMINI_API_KEY=

# gemini-3.1-flash-lite: 500 RPD, 15 RPM — use for classify/summarize/extract
# gemini-2.5-flash: only 20 RPD on free tier — avoid for high-volume pipeline calls
GEMINI_CLASSIFY_MODEL=gemini-3.1-flash-lite
GEMINI_SUMMARIZE_MODEL=gemini-3.1-flash-lite
GEMINI_EXTRACT_MODEL=gemini-3.1-flash-lite
GEMINI_DRAFT_MODEL=gemma-3-27b-it

# ─── Reddit (RSS — no credentials required) ───
# Reddit locked down OAuth for non-Devvit apps in 2026 (Responsible Builder Policy).
# We use public RSS feeds instead: reddit.com/r/{sub}/new.rss
# No setup needed. Just configure subreddits below.

# ─── Google Drive (for exporters → Cowork) ───
# https://console.cloud.google.com/ → create project → enable Docs/Sheets/Drive APIs
# → OAuth 2.0 Client ID (Desktop app) → download JSON to backend/.gcp/oauth_client.json
GOOGLE_OAUTH_CLIENT_FILE=backend/.gcp/oauth_client.json
GOOGLE_TOKEN_FILE=backend/.gcp/token.json
GOOGLE_DRIVE_FOLDER_ID=

LEADS_SHEET_ID=
LEADS_SHEET_TAB=Leads

# ─── Database ───
# v1: local SQLite
DATABASE_URL=sqlite+aiosqlite:///./data.db
# v2: Supabase Postgres — swap to this when deploying
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres

# ─── App config ───
REDDIT_SUBREDDITS=SaaS,Entrepreneur,AI_Agents,automation,n8n,nocode,smallbusiness
HN_KEYWORDS=AI agent,n8n,voice ai,workflow automation,Make.com,GoHighLevel
LOOKBACK_HOURS=24

# ─── Cost guardrails (per UTC day) ───
DAILY_FLASH_CALL_CAP=400
DAILY_GEMMA_CALL_CAP=1000

# ─── Next.js / FastAPI integration ───
# Dashboard reads this to know where the API lives.
BACKEND_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# ─── v2 only (Supabase Auth) — leave empty in v1 ───
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # backend pipeline only; never expose to dashboard
# SUPABASE_JWT_SECRET=         # for FastAPI to verify dashboard requests
