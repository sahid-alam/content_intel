# ─── Gemini (via Google AI Studio, your AI Pro subscription) ───
# Get this from https://aistudio.google.com/app/apikey while signed in to your AI Pro Google account.
# The key inherits your subscription's elevated quota.
GEMINI_API_KEY=

# Models (override only if you want to)
GEMINI_BULK_MODEL=gemini-2.5-flash-lite
GEMINI_PRO_MODEL=gemini-3.1-pro

# ─── Reddit (PRAW OAuth) ───
# Create at https://www.reddit.com/prefs/apps — pick "script" type.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=content-intel/0.1 by /u/YOUR_REDDIT_USERNAME

# ─── App config ───
DATABASE_URL=sqlite+aiosqlite:///./data.db

# Comma-separated. Edit freely; restart not required (read on each /sync).
REDDIT_SUBREDDITS=SaaS,Entrepreneur,AI_Agents,automation,n8n,nocode,smallbusiness

# Comma-separated keyword queries against HN Algolia. Empty = just fetch by date.
HN_KEYWORDS=AI agent,n8n,voice ai,workflow automation,Make.com,GoHighLevel

# How many hours back to look on each sync
LOOKBACK_HOURS=24

# ─── Cost guardrails (hard caps per UTC day) ───
DAILY_FLASH_CALL_CAP=2000
DAILY_PRO_CALL_CAP=50

# ─── CORS / dev ───
FRONTEND_ORIGIN=http://localhost:5173
